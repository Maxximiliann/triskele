# Triskele — required environment variables.
# Copy this file to .env.triskele, fill in the values, and source it from ~/.zshrc.
# NEVER commit the filled-in file. It is .gitignored.

# Kraken REST + WebSocket authentication
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tardis.dev historical data (Phase 5+)
TARDIS_API_KEY=

# Postgres connection (format: ecto://user:pass@host/dbname)
DATABASE_URL=ecto://triskele:secret@localhost/triskele_dev

# Phoenix web server
SECRET_KEY_BASE=
LIVE_VIEW_SIGNING_SALT=

# Operator authentication (bcrypt hash + TOTP secret)
OPERATOR_USERNAME=
OPERATOR_PASSWORD_HASH=
OPERATOR_TOTP_SECRET=

# Display timezone (default: America/Denver)
TIMEZONE=America/Denver

# Kill switch — system starts paused until operator explicitly enables trading
KILL_SWITCH_ON_BOOT=true

# Backblaze B2 encrypted backup
BACKBLAZE_B2_KEY_ID=
BACKBLAZE_B2_APPLICATION_KEY=
BACKBLAZE_B2_BUCKET=

# GPG recipient for encrypted database backups
GPG_RECIPIENT=
